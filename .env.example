# Relic OSS candidate environment

# Core paths
RELIC_DATA_DIR=./runtime
RELIC_DEMO_DIR=./demo
RELIC_SCRIPTS_DIR=

# Hermes scheduler integration
HERMES_HOME=
HERMES_BIN=hermes
RELIC_FOLLOWUP_CRON=relic:checkin-followup

# Optional subject configuration
RELIC_SUBJECT_ID=demo-subject
RELIC_SUBJECT_NAME=Demo Subject

# Optional provider configuration
RELIC_MODEL=
RELIC_PROVIDER=

# Relational agent (agent ID used for passive observation and stress probes)
RELIC_RELATIONAL_AGENT=
RELIC_RELATIONAL_AGENT_IDS=

# Optional integration toggles
RELIC_ENABLE_TELEGRAM=false
RELIC_ENABLE_BIOFEEDBACK=false
RELIC_ENABLE_MUSE=false

# Optional adapter credentials
RELIC_ZEPP_EMAIL=
RELIC_ZEPP_PASSWORD=

# Telegram integration (required if RELIC_ENABLE_TELEGRAM=true or RELIC_ENABLE_MUSE=true)
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGS_CHAT_ID=
TELEGRAM_LOGS_THREAD_ID=

# Inquiry Team - hypothesis verification via structured deliberation (optional feature)
RELIC_INQUIRY_TEAM=false
RELIC_INQUIRY_MODEL=openrouter/free
RELIC_INQUIRY_PRO_MODEL=openrouter/free
RELIC_INQUIRY_CONTRA_MODEL=openrouter/free
TELEGRAM_INQUIRY_CHAT_ID=
TELEGRAM_INQUIRY_THREAD_ID=
RELIC_CORR_TELEGRAM_CHAT_ID=
RELIC_CORR_TELEGRAM_THREAD_ID=
RELIC_HEALTH_TELEGRAM_CHAT_ID=
RELIC_HEALTH_TELEGRAM_THREAD_ID=
RELIC_HUMANNESS_TELEGRAM_CHAT_ID=
RELIC_HUMANNESS_TELEGRAM_THREAD_ID=

# Paperclip integration (optional — run scripts/setup_paperclip.py to populate)
# Requires Paperclip: npm install -g paperclipai && npx paperclipai run
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_COMPANY_ID=
PAPERCLIP_BIO_ANALYST_KEY=
PAPERCLIP_BIO_REVIEWER_ID=
PAPERCLIP_INQ_ANALYST_KEY=
PAPERCLIP_INQ_REVIEWER_ID=
PAPERCLIP_HEALTH_ANALYST_KEY=
PAPERCLIP_HEALTH_REVIEWER_ID=
PAPERCLIP_HUMANNESS_ANALYST_KEY=
PAPERCLIP_HUMANNESS_REVIEWER_ID=
PAPERCLIP_DIRECTOR_ID=
PAPERCLIP_SOCIAL_DRAFTER_KEY=
PAPERCLIP_CEO_ID=
PAPERCLIP_RD_ANALYST_ID=
PAPERCLIP_DEV_PLANNER_ID=
PAPERCLIP_DEV_ENGINEER_ID=
PAPERCLIP_MANUSCRIPT_ID=
PAPERCLIP_DOCS_ID=
PAPERCLIP_COMITATO_ID=

# Social Drafter — Telegram channel for draft X/Twitter posts (human reviews and publishes manually)
RELIC_SOCIAL_TELEGRAM_CHAT_ID=
RELIC_SOCIAL_TELEGRAM_THREAD_ID=
RELIC_SOCIAL_MODEL=

# Humanness Monitor — path to the Hermes profile for the relational agent (reads sessions/)
HERMES_PROFILE_DIR=
